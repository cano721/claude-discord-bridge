# [Required] Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-bot-token-here

# [Required] Discord Server (Guild) ID
DISCORD_GUILD_ID=your-guild-id-here

# Default project directory (optional, can be specified per command)
DEFAULT_PROJECT_DIR=

# Claude Code CLI path (usually just "claude" if installed globally)
CLAUDE_PATH=claude

# Max concurrent tasks (default: 3)
MAX_CONCURRENT_TASKS=3

# Auto-answer questions with coordinator agent (default: false)
AUTO_ANSWER_QUESTIONS=false

# [Security] Authorized Discord user IDs (comma-separated, empty = allow all)
AUTHORIZED_USER_IDS=

# [Security] Allowed project root paths (colon-separated, empty = no restriction)
ALLOWED_PROJECT_ROOTS=

# [Debug] Enable verbose debug logging (set to "1" to enable)
CLAUDE_BRIDGE_DEBUG=0

# [Debug] Log directory for debug output (default: ./logs)
CLAUDE_BRIDGE_LOG_DIR=./logs
